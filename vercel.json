{
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/portfolio-for-ai.js": {
      "maxDuration": 60
    },
    "api/historical-snapshot.js": {
      "maxDuration": 60
    },
    "api/backtest-batch.js": {
      "maxDuration": 60
    },
    "api/backtest-save.js": {
      "maxDuration": 60
    },
    "api/download-historical.js": {
      "maxDuration": 60
    },
    "api/sa-analyze.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    { "path": "/api/cron-daily-brief", "schedule": "0 20 * * *" },
    { "path": "/api/cron-daily-brief", "schedule": "0 14 * * *" }
  ]
}
